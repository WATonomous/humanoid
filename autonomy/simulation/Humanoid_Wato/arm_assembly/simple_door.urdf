<?xml version="1.0"?>
<robot name="simple_door">

  <!-- Door Frame (fixed to world) -->
  <link name="door_frame">
    <visual>
      <geometry>
        <box size="0.05 0.1 2.0"/>
      </geometry>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.1 2.0"/>
      </geometry>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
  </link>

  <!-- Door Panel -->
  <link name="door_panel">
    <visual>
      <geometry>
        <box size="0.05 0.9 2.0"/>
      </geometry>
      <origin xyz="0 0.45 1.0" rpy="0 0 0"/>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.9 2.0"/>
      </geometry>
      <origin xyz="0 0.45 1.0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0.45 1.0" rpy="0 0 0"/>
      <inertia ixx="1.5" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="1.5"/>
    </inertial>
  </link>

  <!-- Hinge Joint: rotates around Z axis, max 30 degrees (~0.524 rad) -->
  <joint name="door_hinge" type="revolute">
    <parent link="door_frame"/>
    <child link="door_panel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.524" effort="50.0" velocity="1.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

</robot>
